{
  "name": "@libreputer/librechat-backend",
  "version": "0.1.0",
  "description": "Express proxy that bridges LibreChat to Puter AI with per-user auth",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --dts-resolve",
    "start": "node dist/index.js",
    "dev": "node dist/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "express": "^4.18.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0"
  }
}