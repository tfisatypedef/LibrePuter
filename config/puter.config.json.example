{
  "config_name": "libreputer",
  "env": "dev",
  "port": 4100,
  "protocol": "http",
  "domain": "puter.localhost",
  "cookie_name": "puter_auth_token",
  "jwt_secret": "change-me-to-a-random-secret",
  "jwt_secret_v2": "change-me-to-another-random-secret",
  "allow_v1_tokens": true,
  "url_signature_secret": "change-me-to-a-url-signature-secret",
  "allow_all_host_values": true,
  "allow_no_host_header": true,
  "database": {
    "engine": "sqlite",
    "path": "volatile/runtime/puter-database.sqlite"
  },
  "s3": {
    "localConfig": {
      "dataDir": "volatile/runtime/fauxqs-data",
      "s3StorageDir": "volatile/runtime/fauxqs-s3-data"
    }
  },
  "providers": {
    "openai-completion": { "apiKey": "sk-your-openai-key" },
    "claude": { "apiKey": "sk-ant-your-claude-key" },
    "gemini": { "apiKey": "your-gemini-key" },
    "groq": { "apiKey": "gsk-your-groq-key" },
    "deepseek": { "apiKey": "sk-your-deepseek-key" },
    "mistral": { "apiKey": "your-mistral-key" },
    "xai": { "apiKey": "your-xai-key" },
    "openrouter": { "apiKey": "sk-or-your-openrouter-key" },
    "together-ai": { "apiKey": "your-together-key" },
    "moonshot": { "apiKey": "your-moonshot-key" },
    "ollama": {
      "enabled": true,
      "apiBaseUrl": "http://localhost:11434"
    }
  }
}