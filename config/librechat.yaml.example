# LibrePuter provides keyless access to 500+ AI models via Puter's User-Pays model.
# Users sign in with their own Puter account and cover their own AI usage costs.
# You do not need any API keys.
#
# For the hosted (keyless) mode, point baseURL at the LibrePuter proxy directly:
endpoints:
  custom:
    - name: "Puter"
      baseURL: "http://localhost:3090/api/puter/proxy/v1"
      apiKey: ""
      models:
        default: []
        fetch: true
      modelDisplayLabel: "Puter AI"
      titleConvo: true

# If LibrePuter is mounted inside LibreChat (patched), use a relative path instead:
#   baseURL: "/api/puter/proxy/v1"