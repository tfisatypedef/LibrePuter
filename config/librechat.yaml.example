# Add this to your LibreChat librechat.yaml to enable Puter AI models.
# The LibrePuter proxy handles authentication with Puter.

endpoints:
  custom:
    - name: "Puter"
      # Points at the LibrePuter proxy, not directly at Puter.
      # The proxy injects the Puter auth cookie transparently.
      baseURL: "/api/puter/proxy/v1"
      # No API key needed - LibrePuter handles Puter auth per-user.
      apiKey: ""
      models:
        default: []
        # Fetch model list from Puter's public API
        fetch: true
      modelDisplayLabel: "Puter AI"
      titleConvo: true