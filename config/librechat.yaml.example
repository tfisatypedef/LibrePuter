# LibrePuter: keyless AI via Puter's User-Pays model.
# Users paste their Puter auth token (from puter.com/dashboard) as the API key.
# No API keys needed from you — users cover their own AI costs.

endpoints:
  custom:
    - name: "Puter AI"
      baseURL: "http://localhost:3090/api/puter/proxy/v1"
      apiKey: "user_provided"
      models:
        default: []
        fetch: true
      modelDisplayLabel: "Puter AI"
      titleConvo: true